flowchart TB
    subgraph L1["Layer 1: Agent Applications"]
        apps(["Agent Applications"])
    end
    
    subgraph L2["Layer 2: Framework / Orchestration"]
        fw(["LangGraph / AutoGen<br/>CrewAI / Custom"])
    end
    
    subgraph L3["Layer 3: Agent Runtime"]
        rt(["Reasoning Loop<br/>Context / State"])
    end
    
    proto{{"Agent Protocol<br/>Open Spec / Contract"}}:::boundary
    
    subgraph L4["Layer 4: Agent Kernel"]
        pr["Protocol Runtime"]
        
        subgraph modules["Kernel Modules"]
            direction LR
            idv[("Identity /<br/>Handle Validation")]
            pe[("Permission<br/>Engine")]
            ar[("Agent<br/>Registry")]
            sch[("Scheduler")]
            sb[("Sandbox")]
            audit[("Audit Log<br/>WAL + Integrity")]
        end
    end
    
    subgraph L5["Layer 5: Execution Substrate"]
        sub["LLM Gateway · Tool Runtime · Memory Store"]
    end
    
    %% Layer connections (solid)
    apps ==> fw ==> rt
    
    %% Protocol boundary (dashed)
    rt -.->|"contract boundary"| proto
    proto -.->|"normalized request"| pr
    
    %% Protocol Runtime to modules
    pr ==> idv
    pr ==> pe
    pr ==> ar
    pr ==> sch
    pr ==> sb
    pr ==> audit
    
    %% Critical path to substrate
    pr ==> sub
    
    %% Module interconnections
    idv -.->|"valid handle"| pe
    pe -.->|"permitted"| sch
    sch -.->|"slot granted"| sb
    sb -.->|"result"| audit
    
    %% Styling classes
    classDef boundary fill:#f5f5f5,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    classDef layer fill:#fff,stroke:#666,stroke-width:1px
    classDef module fill:#fff,stroke:#333,stroke-width:1px
    
    class apps,fw,rt layer
    class idv,pe,ar,sch,sb,audit,module module
